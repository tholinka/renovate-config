{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:recommended",
		"helpers:pinGitHubActionDigests",
		":configMigration",
		"abandonments:recommended",
		"docker:enableMajor",
		"github>tholinka/renovate-config:automerge.json5",
		"github>tholinka/renovate-config:commit-message.json5",
		"github>tholinka/renovate-config:custom-managers.json5",
		"github>tholinka/renovate-config:labels.json5",
		"mergeConfidence:all-badges",
		":enablePreCommit",
		":automergeBranch",
		":disableRateLimiting",
		":dependencyDashboard"
	],
	"timezone": "America/Chicago",
	"dependencyDashboardTitle": "Renovate Dashboard 🤖",
	"suppressNotifications": [
		"prEditedNotification",
		"prIgnoreNotification"
	],
	"rebaseWhen": "auto",
	"platformCommit": "enabled"
}
